{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/absensi/bulk/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/absensi/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/cron/cleanup/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/keuangan/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/keuangan/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/manpower/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/manpower/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/populasi/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/rpc/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/siswa/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/siswa/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}