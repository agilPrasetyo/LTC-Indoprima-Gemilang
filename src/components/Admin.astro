<!-- Modal Edit User Akun -->
<div id="user-edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center glass-modal-bg p-4" onclick="if(event.target===this)closeUserEditModal()">
    <div class="glass-modal-card p-6 md:p-8 rounded-[28px] w-full max-w-md max-h-[90vh] overflow-y-auto space-y-5 transform scale-95 transition-all duration-250">
        <div class="flex items-center justify-between pb-3 border-b border-slate-200/40">
            <h3 class="font-display font-bold text-lg text-brand-textMain flex items-center gap-2">
                <i class="fa-solid fa-user-pen text-brand-blue"></i> Edit Akun Pengguna
            </h3>
            <button onclick="closeUserEditModal()" class="p-2 hover:bg-slate-200/50 rounded-xl text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <input type="hidden" id="edit-user-id">
        <div class="space-y-4">
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Nama Lengkap</label>
                <input type="text" id="edit-user-nama" class="w-full px-4 py-3 bg-white/60 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue transition-all-300">
            </div>
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Email Login</label>
                <input type="email" id="edit-user-email" class="w-full px-4 py-3 bg-white/60 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue transition-all-300">
