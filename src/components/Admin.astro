                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- TAB 3: Log Manpower Harian -->
    <div id="admin-tab-log-manpower" class="admin-tab-content hidden space-y-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Form Log Manpower -->
            <div class="bg-white p-6 rounded-[24px] border border-slate-100 shadow-sm space-y-4 lg:col-span-1 h-fit">
                <h3 class="font-display font-bold text-lg text-brand-textMain border-b border-slate-100 pb-2">Input Log Manpower</h3>
                <div class="space-y-4" id="form-log-manpower">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Pilih Siswa</label>
                        <select id="log-mp-student" onchange="onLogStudentChange()"
                            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue focus:bg-white transition-all-300">
                            <!-- Diisi Dinamis -->
                        </select>
                        <p class="text-[10px] text-brand-textSub mt-1 font-semibold" id="log-mp-label-info"></p>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Tanggal Record</label>
                        <input type="date" id="log-mp-date"
                            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue focus:bg-white transition-all-300">
                    </div>

                    <!-- Fields untuk Produktivitas (Plan / Actual / Reject) -->
                    <div id="log-mp-fields-productivity" class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Plan (Target)</label>
                            <input type="number" id="log-mp-plan" placeholder="0"
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue focus:bg-white transition-all-300">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Aktual</label>
                            <input type="number" id="log-mp-actual" placeholder="0"
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue focus:bg-white transition-all-300">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Reject</label>
                            <input type="number" id="log-mp-reject" placeholder="0"
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue focus:bg-white transition-all-300">
                        </div>
                    </div>

                    <!-- Fields untuk Kehadiran (Hadir / Keterangan) -->
                    <div id="log-mp-fields-attendance" class="space-y-4 hidden">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Status Kehadiran</label>
                            <select id="log-mp-hadir"
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue focus:bg-white transition-all-300">
                                <option value="✔">Hadir (✔)</option>
                                <option value="">Tidak Hadir (Off)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Keterangan / Apa Yang Dikerjakan</label>
                            <textarea id="log-mp-keterangan" rows="3" placeholder="Tulis rincian tugas..."
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue focus:bg-white transition-all-300"></textarea>
                        </div>
                    </div>

                    <button onclick="saveManpowerLogAdmin()"
                        class="w-full py-3 bg-brand-blue text-white font-semibold rounded-xl hover:bg-blue-700 transition-all-300 shadow-md">
                        Simpan Log Harian
                    </button>
                </div>
            </div>

            <!-- Preview 10 Hari Terakhir Log Manpower Siswa Terpilih -->
            <div class="bg-white p-6 rounded-[24px] border border-slate-100 shadow-sm lg:col-span-2 space-y-4">
                <h3 class="font-display font-bold text-lg text-brand-textMain border-b border-slate-100 pb-2">Riwayat Log Harian</h3>
                <div class="overflow-x-auto max-h-[480px]" style="overflow-y: auto;">
                    <table class="w-full text-left text-sm border-collapse">
                        <thead>
                            <tr class="text-brand-textSub text-xs uppercase border-b border-slate-100 bg-white sticky top-0" id="log-mp-preview-thead">
                                <!-- Diisi Dinamis -->
                            </tr>
                        </thead>
                        <tbody id="log-mp-preview-tbody" class="divide-y divide-slate-50 text-xs">
                            <tr>
                                <td colspan="6" class="py-8 text-center text-xs text-brand-textSub italic">Pilih siswa untuk melihat riwayat log harian.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- TAB 4: Kelola Turnover -->
    <div id="admin-tab-kelola-turnover" class="admin-tab-content hidden space-y-6">
        <div class="bg-white p-6 rounded-[24px] border border-slate-100 shadow-sm">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 border-b border-slate-100 pb-4">
                <div>
                    <h3 class="font-display font-bold text-lg text-brand-textMain">Kelola Data Turnover</h3>
