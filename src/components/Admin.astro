                            class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-brand-blue font-bold rounded-xl text-xs flex items-center gap-2 transition-all-300">
                            <i class="fa-solid fa-arrows-spin"></i> Sinkronisasi Siswa Eksternal
                        </button>
