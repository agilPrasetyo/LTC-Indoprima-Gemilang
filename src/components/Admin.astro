                        <tr class="text-brand-textSub text-xs uppercase border-b border-slate-100 sticky top-0 bg-slate-50 z-30">
                            <th class="py-3.5 px-4 font-bold sticky left-0 bg-slate-50 z-20 min-w-[155px] max-w-[155px] w-[155px] shadow-[2px_0_5px_-2px_rgba(0,0,0,0.1)] border-r border-slate-100 text-left">Aksi</th>
                            <th class="py-3.5 px-4 font-bold sticky left-[155px] bg-slate-50 z-20 min-w-[90px] max-w-[90px] w-[90px] shadow-[2px_0_5px_-2px_rgba(0,0,0,0.1)] border-r border-slate-100 text-left">NoReg</th>
                            <th class="py-3.5 px-4 font-bold sticky left-[245px] bg-slate-50 z-20 min-w-[200px] max-w-[200px] w-[200px] shadow-[2px_0_5px_-2px_rgba(0,0,0,0.1)] border-r border-slate-100 text-left">Nama</th>
                            <th class="py-3.5 px-4 font-bold min-w-[120px]">Departemen</th>
                            <th class="py-3.5 px-4 font-bold min-w-[130px]">Section</th>
                            <th class="py-3.5 px-4 font-bold min-w-[100px]">HK</th>
                            <th class="py-3.5 px-4 font-bold min-w-[100px]">Kelas</th>
                            <th class="py-3.5 px-4 font-bold min-w-[100px]">Masuk LTC</th>
                            <th class="py-3.5 px-4 font-bold min-w-[100px]">Distribusi</th>
                            <th class="py-3.5 px-4 font-bold min-w-[100px]">Akhir LTC</th>
                            <th class="py-3.5 px-4 font-bold min-w-[150px]">SPV</th>
                            <th class="py-3.5 px-4 font-bold min-w-[120px]">Daerah Asal</th>
                            <th class="py-3.5 px-4 font-bold min-w-[150px]">Sekolah</th>
