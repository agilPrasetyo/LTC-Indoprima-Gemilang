                            <option value="Visitor">Visitor (Executive View Only)</option>
                            <option value="Siswa">Siswa (Portal Personal)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-brand-textSub mb-2">Nomor Registrasi (Opsional untuk Siswa)</label>
                        <input type="text" id="admin-user-noreg" placeholder="Contoh: 2601190"
