                    </div>
                    <div class="flex flex-wrap items-center gap-3">
                        <div class="relative w-full sm:w-64">
                            <input type="text" id="filter-user-query" oninput="filterAdminUsersTable()" placeholder="Cari nama, email, noreg, role..."
