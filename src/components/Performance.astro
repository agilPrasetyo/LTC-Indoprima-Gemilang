<!-- HALAMAN PERFORMA SISWA (Redesain Menyeluruh) -->
<div class="animate-fadeIn space-y-6">

    <!-- Header & Filter Bar -->
    <div class="bg-white p-6 rounded-[24px] border border-slate-100 shadow-sm">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-5">
            <div>
                <h3 class="font-display font-bold text-xl text-brand-textMain">Performa Siswa LTC</h3>
                <p class="text-xs text-brand-textSub mt-0.5">Rekap capaian performa harian seluruh siswa aktif dalam program</p>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
                <button onclick="exportPerformaCSV()"
                    class="px-4 py-2 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 font-semibold rounded-xl text-xs transition-all duration-200 flex items-center gap-2">
                    <i class="fa-solid fa-file-export"></i> Export CSV
                </button>
                <button onclick="triggerSiswaFilter()"
                    class="px-4 py-2 bg-brand-blue hover:bg-blue-700 text-white font-semibold rounded-xl text-xs transition-all duration-200 flex items-center gap-2">
                    <i class="fa-solid fa-rotate"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Filter Controls -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="col-span-2 md:col-span-1">
                <input type="text" id="search-siswa" oninput="triggerSiswaFilter()"
                    placeholder="🔍 Cari nama / NoReg..."
                    class="w-full px-3 py-2 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue bg-slate-50/70 transition-all duration-200">
            </div>
            <div>
                <select id="filter-kelas-siswa" onchange="triggerSiswaFilter()"
                    class="w-full px-3 py-2 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue bg-white text-brand-textSub font-semibold">
                    <option value="">Semua Kelas</option>
                    <option value="Kelas 1">Kelas 1</option>
                    <option value="Kelas 2">Kelas 2</option>
                    <option value="Kelas 3">Kelas 3</option>
                    <option value="Kelas 4">Kelas 4</option>
                    <option value="Kelas 5">Kelas 5</option>
                </select>
            </div>
            <div>
                <select id="filter-bagian-siswa" onchange="triggerSiswaFilter()"
                    class="w-full px-3 py-2 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue bg-white text-brand-textSub font-semibold">
                    <option value="">Semua Bagian</option>
                </select>
            </div>
            <div>
                <select id="filter-wilayah" onchange="triggerSiswaFilter()"
                    class="w-full px-3 py-2 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue bg-white text-brand-textSub font-semibold">
                    <option value="">Semua Wilayah</option>
                    <option value="SBY">SBY (Surabaya)</option>
                    <option value="BPP">BPP (Balikpapan)</option>
                    <option value="SMG">SMG (Semarang)</option>
                </select>
            </div>
            <div class="md:col-start-4">
                <select id="sort-siswa" onchange="triggerSiswaFilter()"
                    class="w-full px-3 py-2 border border-slate-200 rounded-xl text-xs outline-none focus:border-brand-blue bg-white text-brand-textSub font-semibold">
                    <option value="nama-asc">Nama A→Z</option>
                    <option value="performa-desc">Performa Tertinggi</option>
                    <option value="performa-asc">Performa Terendah</option>
                    <option value="kelas-asc">Kelas Terendah</option>
                    <option value="kelas-desc">Kelas Tertinggi</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Kartu Statistik Ringkasan -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4" id="perf-stat-cards">
        <div class="bg-white p-4 rounded-[20px] border border-slate-100 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
                <span class="p-1.5 rounded-lg bg-teal-50 text-teal-600 text-xs"><i class="fa-solid fa-users"></i></span>
                <span class="text-[10px] font-bold uppercase tracking-wider text-brand-textSub">Total Aktif</span>
            </div>
            <p class="text-3xl font-bold text-brand-textMain" id="perf-stat-total">0</p>
            <p class="text-[10px] text-brand-textSub mt-1">Siswa dalam program</p>
        </div>
        <div class="bg-white p-4 rounded-[20px] border border-slate-100 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
                <span class="p-1.5 rounded-lg bg-blue-50 text-brand-blue text-xs"><i class="fa-solid fa-chart-bar"></i></span>
                <span class="text-[10px] font-bold uppercase tracking-wider text-brand-textSub">Rata-rata</span>
            </div>
            <p class="text-3xl font-bold text-brand-textMain" id="perf-stat-avg">0%</p>
            <p class="text-[10px] text-brand-textSub mt-1">Rata-rata performa</p>
        </div>
        <div class="bg-white p-4 rounded-[20px] border border-slate-100 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
                <span class="p-1.5 rounded-lg bg-emerald-50 text-emerald-600 text-xs"><i class="fa-solid fa-trophy"></i></span>
                <span class="text-[10px] font-bold uppercase tracking-wider text-brand-textSub">Terbaik</span>
            </div>
            <p class="text-3xl font-bold text-emerald-600" id="perf-stat-best">0%</p>
            <p class="text-[10px] text-brand-textSub mt-1 truncate" id="perf-stat-best-name">-</p>
        </div>
        <div class="bg-white p-4 rounded-[20px] border border-slate-100 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
                <span class="p-1.5 rounded-lg bg-rose-50 text-rose-600 text-xs"><i class="fa-solid fa-triangle-exclamation"></i></span>
                <span class="text-[10px] font-bold uppercase tracking-wider text-brand-textSub">Perlu Perhatian</span>
            </div>
            <p class="text-3xl font-bold text-rose-600" id="perf-stat-low">0</p>
            <p class="text-[10px] text-brand-textSub mt-1">Siswa performa &lt; 75%</p>
        </div>
    </div>

    <!-- Tabel Daftar Siswa -->
    <div class="bg-white rounded-[24px] border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <div>
                <span class="text-sm font-bold text-brand-textMain">Daftar Siswa Aktif</span>
                <span class="ml-2 text-xs text-brand-textSub" id="siswa-count-label"></span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></span>
                <span class="text-[10px] font-semibold text-emerald-600">Live Data</span>
            </div>
        </div>
        <div class="overflow-x-auto" style="max-height: 520px; overflow-y: auto;">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                    <tr class="text-brand-textSub text-[10px] uppercase border-b border-slate-100 sticky top-0 bg-slate-50 z-10">
                        <th class="py-3.5 px-4 font-bold">#</th>
                        <th class="py-3.5 px-4 font-bold">No. Registrasi</th>
                        <th class="py-3.5 px-4 font-bold">Nama Lengkap</th>
                        <th class="py-3.5 px-4 font-bold">Bagian</th>
                        <th class="py-3.5 px-4 font-bold">SPV / Wilayah</th>
                        <th class="py-3.5 px-4 font-bold">Kelas</th>
                        <th class="py-3.5 px-4 font-bold min-w-[160px]">Performa</th>
                        <th class="py-3.5 px-4 font-bold text-center">Status</th>
                    </tr>
                </thead>
                <tbody id="siswa-tbody" class="divide-y divide-slate-50"></tbody>
            </table>
        </div>
        <!-- Empty state -->
        <div id="siswa-empty-state" class="hidden flex flex-col items-center justify-center py-16 text-center">
            <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mb-4">
                <i class="fa-solid fa-users-slash text-2xl text-slate-300"></i>
            </div>
            <p class="font-semibold text-brand-textSub">Tidak ada siswa ditemukan</p>
            <p class="text-xs text-slate-400 mt-1">Coba ubah filter pencarian Anda</p>
        </div>
    </div>
</div>
