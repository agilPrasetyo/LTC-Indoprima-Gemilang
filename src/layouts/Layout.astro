---
interface Props {
  title?: string;
}

const { title = "Indoprima Gemilang - LTC Dashboard" } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Pustaka Font & Ikon Tambahan -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght=300;400;500;600;700&family=Urbanist:wght=600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Library Chart.js & Datalabels Plugin untuk visualisasi persentase -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0"></script>
    
    <!-- Peta Interaktif Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- Global CSS import -->
    <script>
      import "../styles/global.css";
    </script>
  </head>
  <body class="min-h-screen bg-brand-bg text-brand-textMain antialiased">
    <slot />
  </body>
</html>
